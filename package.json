{
  "name": "hofi-cli",
  "module": "index.ts",
  "version": "0.0.4",
  "type": "module",
  "private": false,
  "bin": {
    "hofi": "./index.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run index.ts",
    "build": "bun build index.ts --target=bun --minify --outfile dist/hofi.js",
    "compile": "bun build index.ts --compile --minify --outfile ./bin/hofi"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "cac": "^7.0.0",
    "chalk": "^5.6.2",
    "zod": "^4.4.3"
  }
}
